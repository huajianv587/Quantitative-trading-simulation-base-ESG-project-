# AutoDL paper-only runtime template.
# Copy to project-root .env on the AutoDL instance, then fill only paper credentials.

APP_MODE=local
LLM_BACKEND_MODE=auto
PORT=8012
LOCAL_API_URL=http://127.0.0.1:8012

# Qdrant/RAG is intentionally degraded in the AutoDL no-Docker fallback.
QDRANT_URL=http://127.0.0.1:6333
API_HEALTHCHECK_REQUIRED_COMPONENTS=api
RAG_SKIP_AUTOBUILD_ON_READ=true

# Paper scheduler loop.
SCHEDULER_TIMEZONE=America/New_York
SCHEDULER_SIGNAL_UNIVERSE=AAPL,MSFT,TSLA
SCHEDULER_PREOPEN_SIGNAL_TIME=09:00
SCHEDULER_EXECUTION_TIME=09:31
SCHEDULER_HYBRID_WORKFLOW_TIME=09:35
SCHEDULER_EXECUTION_ENGINE=hybrid_paper_workflow
SCHEDULER_OWNER=quant-scheduler
SCHEDULER_REQUIRE_TRADING_SESSION=true
SCHEDULER_REQUIRE_MARKET_CLOCK_FOR_SUBMIT=true
SCHEDULER_CLOSE_GRACE_MINUTES=10
SCHEDULER_AUTO_SUBMIT=true
SCHEDULER_MAX_EXECUTION_SYMBOLS=2
SCHEDULER_MAX_DAILY_NOTIONAL_USD=200.00
SCHEDULER_ENABLE_AUTO_CANCEL=true
SCHEDULER_CANCEL_STALE_AFTER_MINUTES=20
SCHEDULER_ENABLE_AUTO_RETRY=true
SCHEDULER_MAX_RETRY_ATTEMPTS=1
SCHEDULER_RETRY_DELAY_MINUTES=2
SCHEDULER_SYNC_INTERVAL_MINUTES=5
SCHEDULER_SYNC_END_TIME=16:10
SCHEDULER_FAILURE_THRESHOLD=3
SCHEDULER_SYMBOL_FRESHNESS_ENABLED=true
SCHEDULER_FALLBACK_TO_DEFAULT_UNIVERSE=true
SCHEDULER_STATE_PATH=storage/quant/scheduler/runtime_state.json
SCHEDULER_HEARTBEAT_PATH=storage/quant/scheduler/heartbeat.json
SCHEDULER_LOCK_PATH=storage/quant/scheduler/worker.lock
SCHEDULER_LOCK_STALE_MINUTES=240

# RLVR / promotion gate.
PAPER_REWARD_SUBMIT_ENABLED=false
RLVR_HORIZONS=1,3,5
RLVR_WEIGHTS=0.30,0.30,0.40
PAPER_GATE_WINDOW_TRADING_DAYS=60
PAPER_GATE_MIN_VALID_DAYS=60
PROMOTION_POLICY_PATH=configs/promotion_policy.paper.json

# Alpaca paper only. Fill these on the AutoDL host; do not commit secrets.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_ENABLE_LIVE_TRADING=false
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_API_TIMEOUT=20
ALPACA_DEFAULT_TEST_NOTIONAL=100.00
ALPACA_MAX_TEST_ORDERS=2
ALPACA_MAX_ORDER_NOTIONAL=2500.00
ALPACA_PAPER_MAX_ORDER_NOTIONAL=100.00
ALPACA_LIVE_MAX_ORDER_NOTIONAL=1.00
QUANT_BROKER_DEFAULT=alpaca
EXECUTION_PAPER_MAX_NOTIONAL_PER_ORDER=100.00
EXECUTION_KILL_SWITCH=false

# Persistent local state.
MARKET_DATA_CACHE_DB=storage/quant/market_data/bars.sqlite3
MODEL_REGISTRY_PATH=storage/quant/model_registry/current_runtime.json
MODEL_RELEASE_LOG_PATH=storage/quant/model_registry/release_log.jsonl
PAPER_FEEDBACK_DIR=storage/quant/paper_feedback
STORAGE_BACKUP_ENABLED=true
STORAGE_BACKUP_RETENTION_DAYS=30
