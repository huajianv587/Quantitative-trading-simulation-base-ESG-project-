# ============================================
# ESG Quant Intelligence System
# Copy this file to .env and fill the values you need.
# The app can run in local fallback mode with most values left empty.
# ============================================

# Core runtime
APP_MODE=local
LLM_BACKEND_MODE=auto
DEBUG=true
CORS_ORIGINS=*
LOCAL_API_URL=http://127.0.0.1:8000
QUANT_DEFAULT_CAPITAL=1000000
QUANT_DEFAULT_BENCHMARK=SPY
QUANT_DEFAULT_UNIVERSE=ESG_US_LARGE_CAP
SCAN_INTERVAL_MINUTES=30
MAX_SCAN_RESULTS=100

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
REMOTE_LLM_URL=
REMOTE_LLM_API_KEY=
REMOTE_LLM_TIMEOUT=180

# RAG / embeddings
QDRANT_URL=http://127.0.0.1:6333
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=Alibaba-NLP/gte-Qwen2-1.5B-instruct
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_DEVICE=auto
EMBEDDING_LOCAL_FILES_ONLY=false
EMBEDDING_TRUST_REMOTE_CODE=true
EMBEDDING_QUERY_PROMPT_NAME=query
EMBEDDING_TEXT_PROMPT_NAME=document
EMBEDDING_QUERY_INSTRUCTION=
EMBEDDING_TEXT_INSTRUCTION=

# Supabase
SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=
SUPABASE_PASSWORD=
SUPABASE_STORAGE_BUCKET=quant-artifacts
SUPABASE_STORAGE_PUBLIC=true
SUPABASE_STORAGE_PATH_PREFIX=quant

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@esg-system.com

# Market / ESG / news data sources
ALPHA_VANTAGE_KEY=
ALPHA_VANTAGE_API_KEY=
HYFINNAN_API_KEY=
NEWS_API_KEY=
NEWSAPI_KEY=
FINNHUB_API_KEY=
RAPIDAPI_KEY=
RAPIDAPI_HOST=yh-finance.p.rapidapi.com
SEC_EDGAR_EMAIL=
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_TIMEOUT=20
ALPACA_DEFAULT_TEST_NOTIONAL=1.00
ALPACA_MAX_TEST_ORDERS=2
ALPACA_MAX_ORDER_NOTIONAL=10.00
ALPACA_ENABLE_LIVE_TRADING=false

# Remote serving / training
REMOTE_TRAINING_TARGET=Cloud RTX 5090 Finetune Node
REMOTE_LLM_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
REMOTE_LLM_ADAPTER_PATH=model-serving/checkpoint
REMOTE_LLM_HOST=127.0.0.1
REMOTE_LLM_PORT=8010
REMOTE_LLM_ALLOW_CPU=false
REMOTE_GPU_SSH_HOST=
REMOTE_GPU_SSH_PORT=22
REMOTE_GPU_SSH_USER=root
REMOTE_GPU_FORWARD_LOCAL_PORT=8010
REMOTE_GPU_FORWARD_REMOTE_PORT=8010
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
TRAINING_S3_BUCKET=jiang-data-2026-esg-training
TRAINING_S3_PREFIX=esg-finetune/data
TRAINING_S3_OUTPUT_PREFIX=esg-finetune/output
SAGEMAKER_EXECUTION_ROLE_ARN=arn:aws:iam::935154424717:role/ESGtrainer
TRAINING_REPO_URL=https://github.com/huajianv587/ESG_Agentic.git
