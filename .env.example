# ════════════════════════════════════════════════════════════════════════════
# ESG Agentic RAG Copilot - 环境配置文件示例
# ════════════════════════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际的配置值

# ────────────────────────────────────────────────────────────────────────────
# 1. LLM 配置 - Claude API
# ────────────────────────────────────────────────────────────────────────────
# Anthropic Claude API Key
# 获取地址：https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key（Fallback LLM）
# 获取地址：https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API Key（作为最后的Fallback）
# 获取地址：https://platform.deepseek.com/api/keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────────────────────
# 2. 数据库配置 - Supabase PostgreSQL
# ────────────────────────────────────────────────────────────────────────────
# Supabase 项目URL
# 获取地址：https://app.supabase.com/projects
SUPABASE_URL=https://your-project.supabase.co

# Supabase API Key（anon key 用于客户端，service_role key 用于服务器）
SUPABASE_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key（敏感，仅用于服务器端）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────────────────────────────────
# 3. 向量数据库配置 - 用于RAG检索
# ────────────────────────────────────────────────────────────────────────────
# FAISS 本地向量数据库（无需配置，使用本地文件）
VECTOR_DB_TYPE=faiss
VECTOR_DB_PATH=./data/vector_db

# Pinecone 向量数据库（可选的云端替代）
# PINECONE_API_KEY=xxxxxxxxxxxxxx
# PINECONE_ENVIRONMENT=us-west1-gcp
# PINECONE_INDEX_NAME=esg-index

# ────────────────────────────────────────────────────────────────────────────
# 4. 金融数据源 API - Alpha Vantage
# ────────────────────────────────────────────────────────────────────────────
# 用于获取股价、财务数据、技术指标
# 获取地址：https://www.alphavantage.co/
# 免费版本限制：5次/分钟，25次/天
ALPHA_VANTAGE_API_KEY=demo  # 替换为你的API key

# ────────────────────────────────────────────────────────────────────────────
# 5. ESG评级数据源 API - Hyfinnan（示例）
# ────────────────────────────────────────────────────────────────────────────
# 替代方案：Bloomberg Terminal、Refinitiv Eikon、Sustainalytics
# 获取地址：https://www.hyfinnan.com/ 或其他数据服务商
HYFINNAN_API_KEY=your_api_key_here

# ────────────────────────────────────────────────────────────────────────────
# 6. SEC EDGAR API - 获取美国上市公司官方披露文件
# ────────────────────────────────────────────────────────────────────────────
# 获取地址：https://www.sec.gov/cgi-bin/browse-edgar
# SEC EDGAR 的邮箱（作为User-Agent）
SEC_EDGAR_EMAIL=your_email@example.com

# ────────────────────────────────────────────────────────────────────────────
# 7. 新闻API - NewsAPI 用于拉取ESG相关新闻
# ────────────────────────────────────────────────────────────────────────────
# 获取地址：https://newsapi.org/
# 免费版本限制：100次/天
NEWSAPI_KEY=your_newsapi_key_here

# ────────────────────────────────────────────────────────────────────────────
# 8. 金融数据API - Finnhub 用于股票和企业数据
# ────────────────────────────────────────────────────────────────────────────
# 获取地址：https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key

# ────────────────────────────────────────────────────────────────────────────
# 9. 邮件配置 - 用于推送通知
# ────────────────────────────────────────────────────────────────────────────
# SMTP服务器配置（用于发送邮件通知）
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password  # 使用应用专用密码而非账户密码

# 邮件发送者信息
MAIL_FROM_NAME=ESG Copilot
MAIL_FROM_ADDRESS=noreply@esg-copilot.com

# ────────────────────────────────────────────────────────────────────────────
# 10. Webhook配置 - 用于接收和发送数据
# ────────────────────────────────────────────────────────────────────────────
# Webhook 签名密钥（用于验证请求）
WEBHOOK_SECRET_KEY=your_webhook_secret_key

# Slack Webhook（可选，用于在Slack发送通知）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Webhook（可选）
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR/WEBHOOK

# ────────────────────────────────────────────────────────────────────────────
# 11. 应用配置
# ────────────────────────────────────────────────────────────────────────────
# 应用环境
ENVIRONMENT=development  # development, staging, production

# 应用名称和版本
APP_NAME=ESG Agentic RAG Copilot
APP_VERSION=1.0.0

# FastAPI 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=true  # 开发环境启用自动重载

# 日志级别
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# 时区设置
TIMEZONE=UTC

# ────────────────────────────────────────────────────────────────────────────
# 12. RAG 和向量搜索配置
# ────────────────────────────────────────────────────────────────────────────
# 向量嵌入模型
EMBEDDING_MODEL=text-embedding-3-small  # OpenAI embedding model
EMBEDDING_BATCH_SIZE=100

# 相似度搜索配置
SIMILARITY_THRESHOLD=0.6  # 相似度阈值
TOP_K_RESULTS=5  # 返回Top K个最相似的结果

# RAG 数据源
RAG_DATA_PATH=./data/rag_documents
RAG_INDEX_PATH=./data/rag_index

# ────────────────────────────────────────────────────────────────────────────
# 13. 微调模型配置
# ────────────────────────────────────────────────────────────────────────────
# 本地模型（LoRA 微调模型）
LOCAL_MODEL_TYPE=llama2  # llama2, mistral, etc.
LOCAL_MODEL_PATH=./models/llama2-7b-chat-hf
LORA_MODEL_PATH=./models/lora_weights

# GPU 配置（如果使用本地模型）
USE_GPU=false
GPU_DEVICE_ID=0

# ────────────────────────────────────────────────────────────────────────────
# 14. 缓存配置
# ────────────────────────────────────────────────────────────────────────────
# 缓存类型
CACHE_TYPE=redis  # redis, memory, file

# Redis 缓存（如果使用 Redis）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # 如果有密码

# 缓存过期时间（秒）
CACHE_TTL=3600

# ────────────────────────────────────────────────────────────────────────────
# 15. 任务调度配置
# ────────────────────────────────────────────────────────────────────────────
# 报告生成调度时间（24小时制）
DAILY_REPORT_TIME=06:00
WEEKLY_REPORT_TIME=08:00  # 每周一
MONTHLY_REPORT_TIME=09:00  # 每月1日

# 数据源同步间隔（小时）
DATA_SYNC_INTERVAL=6

# Scanner 扫描间隔（分钟）
SCANNER_INTERVAL=30

# ────────────────────────────────────────────────────────────────────────────
# 16. 推送和通知配置
# ────────────────────────────────────────────────────────────────────────────
# 推送频率限制（同一用户，防止刷屏）
PUSH_RATE_LIMIT=5  # 每小时最多推送N条

# 推送重试次数
PUSH_MAX_RETRIES=3

# 推送超时（秒）
PUSH_TIMEOUT=30

# ────────────────────────────────────────────────────────────────────────────
# 17. 安全配置
# ────────────────────────────────────────────────────────────────────────────
# CORS 允许的源
CORS_ORIGINS=["http://localhost:3000", "https://your-frontend.com"]

# JWT 密钥
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # 秒

# ────────────────────────────────────────────────────────────────────────────
# 18. 第三方服务集成（可选）
# ────────────────────────────────────────────────────────────────────────────
# Google Analytics（可选）
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Sentry 错误跟踪（可选）
SENTRY_DSN=https://key@sentry.io/1234567

# ────────────────────────────────────────────────────────────────────────────
# 注意事项：
# ────────────────────────────────────────────────────────────────────────────
# 1. 不要提交 .env 文件到版本控制系统（git）
# 2. 在生产环境中使用强密码和安全的密钥
# 3. 定期轮换 API 密钥
# 4. 使用环境变量或密钥管理服务（如AWS Secrets Manager）
# 5. 在 CI/CD 管道中安全地注入敏感信息
#
# API 获取指南：
# ────────────────────────────────────────────────────────────────────────────
# ✓ Anthropic Claude API：https://console.anthropic.com/account/keys
# ✓ OpenAI API：https://platform.openai.com/account/api-keys
# ✓ Alpha Vantage：https://www.alphavantage.co/
# ✓ NewsAPI：https://newsapi.org/
# ✓ Finnhub：https://finnhub.io/dashboard/api-tokens
# ✓ Supabase：https://app.supabase.com/
# ✓ Slack Webhook：https://api.slack.com/messaging/webhooks
# ✓ Gmail SMTP：https://support.google.com/mail/answer/185833
